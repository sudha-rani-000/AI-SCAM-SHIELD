# Copy this file to .env and fill in your own values.
# Get MONGODB_URI from your MongoDB Atlas cluster: Database > Connect > Drivers.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/aiscamshield?retryWrites=true&w=majority

# Any long random string works. Example generator: `openssl rand -hex 32`
JWT_SECRET=replace-this-with-a-long-random-string

PORT=4000

# The origin your frontend runs on, so CORS allows it.
CLIENT_ORIGIN=http://localhost:5173
